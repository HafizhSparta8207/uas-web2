generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(100)
  email         String          @unique @db.VarChar(100)
  password      String          @db.VarChar(255)
  role          Role            @default(BUYER)
  phone         String?         @db.VarChar(20)
  avatarUrl     String?         @map("avatar_url") @db.VarChar(255)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  sellerProfile SellerProfile?
  addresses     Address[]
  cart          Cart?
  ordersAsBuyer Order[]         @relation("BuyerOrders")
  orderItems    OrderItem[]     @relation("SellerOrderItems")
  reviews       Review[]        @relation("BuyerReviews")
  books         Book[]

  @@map("users")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model SellerProfile {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique @map("user_id")
  storeName        String   @map("store_name") @db.VarChar(100)
  storeDescription String?  @map("store_description") @db.Text
  storeLogoUrl     String?  @map("store_logo_url") @db.VarChar(255)
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id])

  @@map("seller_profiles")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(50)
  slug  String @unique @db.VarChar(50)
  books Book[]

  @@map("categories")
}

model Book {
  id              Int           @id @default(autoincrement())
  sellerId        Int           @map("seller_id")
  categoryId      Int           @map("category_id")
  title           String        @db.VarChar(150)
  author          String        @db.VarChar(100)
  isbn            String?       @db.VarChar(20)
  description     String?       @db.Text
  price           Decimal       @db.Decimal(10, 2)
  stock           Int           @default(0)
  origin          String        @default("Indonesia") @db.VarChar(50)
  conditionStatus Condition     @default(NEW) @map("condition_status")
  coverImageUrl   String?       @map("cover_image_url") @db.LongText
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  seller          User          @relation(fields: [sellerId], references: [id])
  category        Category      @relation(fields: [categoryId], references: [id])
  images          BookImage[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  reviews         Review[]

  @@map("books")
}

enum Condition {
  NEW
  USED
}

model BookImage {
  id       Int    @id @default(autoincrement())
  bookId   Int    @map("book_id")
  imageUrl String @map("image_url") @db.VarChar(255)
  book     Book   @relation(fields: [bookId], references: [id])

  @@map("book_images")
}

model Address {
  id            Int     @id @default(autoincrement())
  userId        Int     @map("user_id")
  recipientName String  @map("recipient_name") @db.VarChar(100)
  phone         String  @db.VarChar(20)
  fullAddress   String  @map("full_address") @db.Text
  city          String  @db.VarChar(50)
  province      String  @db.VarChar(50)
  postalCode    String  @map("postal_code") @db.VarChar(10)
  isDefault     Boolean @default(false) @map("is_default")
  user          User    @relation(fields: [userId], references: [id])
  orders        Order[]

  @@map("addresses")
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id       Int  @id @default(autoincrement())
  cartId   Int  @map("cart_id")
  bookId   Int  @map("book_id")
  quantity Int  @default(1)
  cart     Cart @relation(fields: [cartId], references: [id])
  book     Book @relation(fields: [bookId], references: [id])

  @@map("cart_items")
}

model Order {
  id            Int         @id @default(autoincrement())
  buyerId       Int         @map("buyer_id")
  addressId     Int         @map("address_id")
  totalAmount   Decimal     @map("total_amount") @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  paymentMethod String?     @map("payment_method") @db.VarChar(50)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  buyer         User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  address       Address     @relation(fields: [addressId], references: [id])
  items         OrderItem[]
  payments      Payment[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int      @map("order_id")
  bookId          Int      @map("book_id")
  sellerId        Int      @map("seller_id")
  quantity        Int
  priceAtPurchase Decimal  @map("price_at_purchase") @db.Decimal(10, 2)
  order           Order    @relation(fields: [orderId], references: [id])
  book            Book     @relation(fields: [bookId], references: [id])
  seller          User     @relation("SellerOrderItems", fields: [sellerId], references: [id])
  reviews         Review[]

  @@map("order_items")
}

model Review {
  id          Int       @id @default(autoincrement())
  orderItemId Int       @map("order_item_id")
  buyerId     Int       @map("buyer_id")
  bookId      Int       @map("book_id")
  rating      Int       @db.TinyInt
  comment     String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  buyer       User      @relation("BuyerReviews", fields: [buyerId], references: [id])
  book        Book      @relation(fields: [bookId], references: [id])

  @@map("reviews")
}

model Payment {
  id       Int           @id @default(autoincrement())
  orderId  Int           @map("order_id")
  method   String        @db.VarChar(50)
  amount   Decimal       @db.Decimal(10, 2)
  status   PaymentStatus @default(PENDING)
  paidAt   DateTime?     @map("paid_at")
  order    Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
